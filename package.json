{
    "name": "glucose-admin-api",
    "version": "0.0.1",
    "description": "Glucose admin panel API (NestJS 11). Reads/writes shared MySQL via curated subset Prisma schema.",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "prisma:pull": "prisma db pull && prisma generate",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "node scripts/forbid-migrate.cjs",
        "prisma:migrate:dev": "node scripts/forbid-migrate.cjs",
        "prisma:migrate:deploy": "node scripts/forbid-migrate.cjs",
        "prisma:migrate:reset": "node scripts/forbid-migrate.cjs",
        "prisma:migrate:resolve": "node scripts/forbid-migrate.cjs",
        "prisma:migrate:status": "node scripts/forbid-migrate.cjs",
        "ci:prisma-drift": "bash scripts/ci-prisma-drift.sh",
        "ci:forbid-migrations-dir": "bash scripts/ci-forbid-migrations-dir.sh",
        "ci:audit-required": "node scripts/ci-audit-decorator-check.cjs",
        "ci:audit-required:self-test:fail": "node -e \"const {spawnSync}=require('child_process');const r=spawnSync(process.execPath,['scripts/ci-audit-decorator-check.cjs','scripts/__fixtures__/audit-violation.controller.ts'],{stdio:'inherit'});process.exit(r.status===1?0:1);\"",
        "ci:audit-required:self-test:pass": "node scripts/ci-audit-decorator-check.cjs scripts/__fixtures__/audit-passing.controller.ts"
    },
    "dependencies": {
        "@nestjs-modules/ioredis": "^2.0.2",
        "@nestjs-modules/mailer": "^2.0.1",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.1",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/schedule": "^6.0.0",
        "@nestjs/swagger": "^11.0.0",
        "@nestjs/throttler": "^6.0.0",
        "@prisma/client": "^6.7.0",
        "axios": "^1.9.0",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "helmet": "^8.0.0",
        "ioredis": "^5.9.3",
        "nest-winston": "^1.10.2",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^5.0.0",
        "@types/node": "^22.18.8",
        "prettier": "^3.4.2",
        "prisma": "^6.8.1",
        "source-map-support": "^0.5.21",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3"
    }
}
