# ─────────────────────────────────────────────────────────────────────
# PHASE 2: ADMIN AUTH (cookie-flow + JWT + Redis allowlist + audit)
# ─────────────────────────────────────────────────────────────────────
# JWT_ADMIN_SECRET MUST also be set in glucose-admin-client/.env (same
# exact value, NO NEXT_PUBLIC_ prefix) so the Edge middleware can verify
# access tokens with the shared HS256 secret.
#
# Cookies set by POST /admin-api/auth/login (and mirrored by Next.js BFF):
#   glc_admin_at  — access  (15-minute TTL, HttpOnly, SameSite=Lax)
#   glc_admin_rt  — refresh (7-day TTL, jti tracked in Redis allowlist
#                            at key geonline-admin:refresh:<jti>)
#
# Audit log: NDJSON written to glucose-admin-api/logs/admin-audit.log
# (5MB rotate, 10 files). The future replay script (Phase 1 Pass B
# follow-up) inserts these rows into AdminAuditLog once SCH-01 lands.
# ─────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4101

# Database — shared MySQL with glucose-api, but with constrained pool
# Per FND-04, admin-api's connection pool is capped at 5.
# Total budget across cluster: glucose-api (~10/instance × 4 instances = 40) + admin-api (5) = 45.
DATABASE_URL="mysql://user:pass@host:3306/glucose?connection_limit=5"

# JWT — DEDICATED admin secret (not glucose-api's JWT_SECRET)
JWT_ADMIN_SECRET="change-me-to-a-strong-random-32-byte-secret-min"
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_TTL=7d
# Numeric seconds — must match JWT_ADMIN_REFRESH_TTL ('7d' = 604800).
# Consumed by the Redis jti allowlist (TTL on geonline-admin:refresh:<jti>).
JWT_ADMIN_REFRESH_TTL_SECONDS=604800

# Redis — shared instance with glucose-api; admin uses geonline-admin:* namespace
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS — explicit allowlist; NEVER set to "*"
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4100

# Optional — populated at deploy time so /admin-api/health can report it
GIT_SHA=

# ── Production / PM2 deploy ───────────────────────────────────────
# PM2 sets PORT=4101 from glucose-api/ecosystem.config.js. Don't override here.
# All secrets MUST be set in the server's process environment (or PM2 env_production
# block in a non-committed ecosystem.deploy.js). DO NOT commit real values.
#
# Required at deploy time:
#   DATABASE_URL=mysql://<prod-user>:<pass>@<prod-host>:3306/glucose?connection_limit=5
#   JWT_ADMIN_SECRET=<32+ char random>
#   REDIS_HOST=<prod-redis>
#   REDIS_PORT=6379
#   REDIS_PASSWORD=<prod-redis-password>
#   CORS_ORIGINS=https://<your-admin-host>
#   GIT_SHA=<commit-sha-set-by-deploy-script>
