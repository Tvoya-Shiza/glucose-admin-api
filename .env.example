# ─────────────────────────────────────────────────────────────────────
# PHASE 2: ADMIN AUTH (cookie-flow + JWT + Redis allowlist + audit)
# ─────────────────────────────────────────────────────────────────────
# JWT_ADMIN_SECRET MUST also be set in glucose-admin-client/.env (same
# exact value, NO NEXT_PUBLIC_ prefix) so the Edge middleware can verify
# access tokens with the shared HS256 secret.
#
# Cookies set by POST /admin-api/auth/login (and mirrored by Next.js BFF):
#   glc_admin_at  — access  (15-minute TTL, HttpOnly, SameSite=Lax)
#   glc_admin_rt  — refresh (7-day TTL, jti tracked in Redis allowlist
#                            at key geonline-admin:refresh:<jti>)
#
# Audit log: NDJSON written to glucose-admin-api/logs/admin-audit.log
# (5MB rotate, 10 files). The future replay script (Phase 1 Pass B
# follow-up) inserts these rows into AdminAuditLog once SCH-01 lands.
# ─────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4101

# Database — shared MySQL with glucose-api, but with constrained pool
# Per FND-04, admin-api's connection pool is capped at 5.
# Total budget across cluster: glucose-api (~10/instance × 4 instances = 40) + admin-api (5) = 45.
DATABASE_URL="mysql://user:pass@host:3306/glucose?connection_limit=5"

# JWT — DEDICATED admin secret (not glucose-api's JWT_SECRET)
JWT_ADMIN_SECRET="change-me-to-a-strong-random-32-byte-secret-min"
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_TTL=7d
# Numeric seconds — must match JWT_ADMIN_REFRESH_TTL ('7d' = 604800).
# Consumed by the Redis jti allowlist (TTL on geonline-admin:refresh:<jti>).
JWT_ADMIN_REFRESH_TTL_SECONDS=604800

# Redis — shared instance with glucose-api; admin uses geonline-admin:* namespace
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS — explicit allowlist; NEVER set to "*"
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4100

# Optional — populated at deploy time so /admin-api/health can report it
GIT_SHA=

# ─────────────────────────────────────────────────────────────────────
# PHASE 5 PLAN 04: FILE UPLOAD (BFF-BYPASS — CRS-05)
# ─────────────────────────────────────────────────────────────────────
# Browser sends files DIRECTLY to admin-api (not through Next.js BFF) per
# CONTEXT D-13. The X-Upload-Token header (a 5-minute single-use JWT) IS
# the credential — admin Bearer cookie is intentionally NOT trusted on
# the file-upload route.
#
# JWT_UPLOAD_SECRET is intentionally distinct from JWT_ADMIN_SECRET so a
# leaked admin token can't be replayed as an upload token (T-05-42).
# Min length: 32 chars (env validation rejects shorter values at boot).
#
# UPLOAD_BASE_DIR is created at boot with mode 0750 if missing. Must be
# owned by the service user that runs admin-api (PM2). nginx serves the
# directory statically at UPLOAD_PUBLIC_URL_PREFIX — see
# .planning/phases/05-courses-webinars/05-PLAN-04-NGINX-SNIPPET.md.
#
# DEV: leave UPLOAD_BASE_DIR unset to default to ./.uploads/courses (gitignored)
# so contributors don't need sudo for /var/data. Set UPLOAD_SERVE_STATIC=true
# in dev so Nest itself serves /static/courses (no nginx required).
# PROD: keep UPLOAD_SERVE_STATIC unset/false; nginx maps /static/courses to disk.
# ─────────────────────────────────────────────────────────────────────
JWT_UPLOAD_SECRET=
UPLOAD_BASE_DIR=./.uploads/courses
UPLOAD_PUBLIC_URL_PREFIX=/static/courses
UPLOAD_SERVE_STATIC=true

# ─────────────────────────────────────────────────────────────────────
# SHARED UPLOADS VOLUME (assignment submission attachments)
# ─────────────────────────────────────────────────────────────────────
# Root of the docker volume `uploads-data` that both user-api (glucose-api)
# and admin-api mount at /uploads in prod. admin-api streams student
# submission files from `<root>/assignment_messages/<file>` through the BFF
# proxy so the browser never gets a raw legacy storage URL (AUTH-08).
#
# DEV: point this at wherever glucose-api stores its UPLOAD_BASE_DIR (one
# level up from `assignment_messages/`). If you don't have local fixtures,
# leave this unset — the file endpoint will 404 for legacy submissions.
# PROD: docker-compose mounts /uploads automatically; leave default.
# ─────────────────────────────────────────────────────────────────────
SHARED_STORAGE_BASE_DIR=

# ─────────────────────────────────────────────────────────────────────
# PHASE 6 PLAN 04: FORCE-CONFIRM TOKENS FOR DESTRUCTIVE QUIZ EDITS (QZ-06)
# ─────────────────────────────────────────────────────────────────────
# Plan 05's destructive-edit handlers (changing question/answer text,
# changing answer correctness, deleting a question/answer) check for
# open `QuizResult.status='waiting'` rows. If any exist, the response
# is 409 with a force_confirm_token; the client re-submits the same
# DTO with the token populated; on success the server bumps
# Quizzes.version by 1 (D-11..D-14).
#
# JWT_QUIZ_FORCE_SECRET is intentionally distinct from JWT_ADMIN_SECRET
# and JWT_UPLOAD_SECRET so confused-deputy attempts (presenting an admin
# Bearer or upload token as a force-confirm token) reject at signature
# verification (T-06-44).
#
# Min length: 32 chars (env validation rejects shorter values at boot).
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────
JWT_QUIZ_FORCE_SECRET=

# ─────────────────────────────────────────────────────────────────────
# PHASE 8: PUSH NOTIFICATIONS + MAILINGS
# ─────────────────────────────────────────────────────────────────────
# Firebase / FCM — same project + service account as glucose-api.
# Copy these EXACTLY from glucose-api/.env (do not generate a new key
# unless the team rotates the service-account credentials globally).
# When any of the three is missing, PushFcmService logs a warning at
# boot and sendToToken/sendToUser silently no-op (matches glucose-api
# auto-trigger fallback behaviour).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# SMTP — used by MailerService for admin mailings (PSH-05/06).
# Production: a transactional-mail provider (Mailgun / SendGrid / SES SMTP relay).
# Dev: leave SMTP_HOST blank → MailerService.sendMail returns
#   {success:false, error:'no-smtp-config'} without throwing
# (matches PushFcmService no-op pattern).
# SMTP_FROM is the From: header sent on the wire (e.g. "Glucose Admin <noreply@glucose.kz>")
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

# ── Production / PM2 deploy ───────────────────────────────────────
# PM2 sets PORT=4101 from glucose-api/ecosystem.config.js. Don't override here.
# All secrets MUST be set in the server's process environment (or PM2 env_production
# block in a non-committed ecosystem.deploy.js). DO NOT commit real values.
#
# Required at deploy time:
#   DATABASE_URL=mysql://<prod-user>:<pass>@<prod-host>:3306/glucose?connection_limit=5
#   JWT_ADMIN_SECRET=<32+ char random>
#   REDIS_HOST=<prod-redis>
#   REDIS_PORT=6379
#   REDIS_PASSWORD=<prod-redis-password>
#   CORS_ORIGINS=https://<your-admin-host>
#   GIT_SHA=<commit-sha-set-by-deploy-script>
