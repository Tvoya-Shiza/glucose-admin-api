/// Phase 19 — per-item content unlock gates.
///
/// Granted by an admin to either a single user OR a single group (xor — enforced
/// at the application layer in progress-overrides.service.ts; a DB-level CHECK
/// would conflict with the CASCADE FKs per MySQL 8 error 3823). The two composite
/// UNIQUE indexes (uniq_cco_user_course_item, uniq_cco_group_course_item) also
/// prevent duplicate grants per (target, course, item). When evaluating "can view
/// item N": course access exists AND (strict_progress=false OR previous items
/// completed OR a matching override row exists).
///
/// NEVER writes to CourseLearning.passed — pure access gate.
///
/// expires_at is NULL for perpetual unlocks. When set, view-time check ignores
/// rows past their expiry.
model CourseContentOverride {
  id                  Int     @id @default(autoincrement()) @db.UnsignedInt
  user_id             Int?
  group_id            Int?    @db.UnsignedInt
  webinar_id          Int
  item_id             Int
  granted_by_admin_id Int?
  note                String? @db.VarChar(255)
  created_at          Int     @db.UnsignedInt
  expires_at          Int?    @db.UnsignedInt

  user             User?              @relation("UserContentOverrides", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  group            Group?             @relation("GroupContentOverrides", fields: [group_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  webinar          Webinar            @relation("WebinarContentOverrides", fields: [webinar_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  item             WebinarChapterItem @relation("ItemContentOverrides", fields: [item_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  granted_by_admin User?              @relation("AdminGrantedContentOverrides", fields: [granted_by_admin_id], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@unique([user_id, webinar_id, item_id], name: "uniq_cco_user_course_item")
  @@unique([group_id, webinar_id, item_id], name: "uniq_cco_group_course_item")
  @@index([webinar_id])
  @@index([item_id])
  @@index([user_id, webinar_id], name: "idx_cco_user_course")
  @@index([group_id, webinar_id], name: "idx_cco_group_course")
  @@index([expires_at])
  @@map("course_content_overrides")
}

