// Phase 10 — Mirror of glucose-api/prisma/schema.prisma FileFolder.
// Canonical schema + migration live in glucose-api. Mirror only here.
// See glucose-api/prisma/migrations/phase-10-file-folders.MANUAL.sql.md.
model FileFolder {
