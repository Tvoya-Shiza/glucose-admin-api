generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int        @id @default(autoincrement()) @db.UnsignedInt
  full_name         String?    @db.VarChar(255)
  last_activity     DateTime?
  role_name         String     @db.VarChar(64)
  role_id           Int        @db.UnsignedInt 
  referrer_id       Int?
  mobile            String?    @unique @db.VarChar(32)
  email             String?    @unique @db.VarChar(255)
  password          String?    @db.VarChar(255)
  verified          Boolean    @default(false)
  avatar            String?    @db.VarChar(255)
  about             String?    @db.Text
  country_id        Int?
  province_id       Int?
  city_id           Int?
  district_id       Int?
  school_id         Int?
  school_subject_id Int?
  status            UserStatus @default(active)
  created_at        Int
  updated_at        Int?
  deleted_at        Int?
  country           Region?    @relation("CountryUsers", fields: [country_id], references: [id])
  province          Region?    @relation("ProvinceUsers", fields: [province_id], references: [id])
  city              Region?    @relation("CityUsers", fields: [city_id], references: [id])
  district          Region?    @relation("DistrictUsers", fields: [district_id], references: [id])
  school            Region?    @relation("SchoolUsers", fields: [school_id], references: [id])

  role Role @relation("RoleUsers", fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  school_subject SchoolSubject? @relation("SchoolSubjectUsers", fields: [school_subject_id], references: [id])

  quiz_results       QuizResult[]      @relation("QuizResults")
  quiz_badge_results QuizBadgeResult[] @relation("QuizBadgeResults")

  codes Verification[]

  referral_code UserReferralCode? @relation("UserReferralCode")

  referrer  User?  @relation("UserReferrer", fields: [referrer_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  referrals User[] @relation("UserReferrer")

  webinar_creators Webinar[] @relation("WebinarCreators")
  webinar_teachers Webinar[] @relation("WebinarTeachers")

  reviews WebinarReviews[] @relation("WebinarReviews")

  rewards RewardAccounting[] @relation("RewardAccounting")

  login_histories UserLoginHistory[] @relation("UserLoginHistories")

  firebase_sessions UserFirebaseSession[] @relation("UserFirebaseSessions")

  instructor_assignment_histories WebinarAssignmentHistory[] @relation("InstructorAssignmentHistory")
  student_assignment_histories    WebinarAssignmentHistory[] @relation("StudentAssignmentHistory")
  teacher_chapter_schedules       WebinarChapterSchedule[]   @relation("TeacherChapterSchedule")

  lesson_schedules_as_curator LessonSchedule[] @relation("LessonScheduleCurator")
  lesson_schedules_created    LessonSchedule[] @relation("LessonScheduleCreator")

  group_users             GroupUser[]          @relation("GroupUsers")
  created_groups          Group[]              @relation("GroupCreator")
  supervised_groups       Group[]              @relation("GroupSupervisor")
  authored_blogs          Blog[]               @relation("BlogAuthor")
  authored_advertisements Advertisement[]      @relation("AdvertisementAuthor")
  authored_stories        Story[]              @relation("StoryAuthor")
  received_notifications  Notification[]       @relation("UserNotifications")
  sent_notifications      Notification[]       @relation("SentNotifications")
  notification_statuses   NotificationStatus[] @relation("UserNotificationStatuses")
  carts                   Cart[]

  orders                Order[]                           @relation("OrderUser")
  sales_as_seller       Sale[]                            @relation("SaleSeller")
  sales_as_buyer        Sale[]                            @relation("SaleBuyer")
  created_assignments   WebinarAssignment[]               @relation("AssignmentCreator")
  created_chapters      WebinarChapter[]                  @relation("ChapterCreator")
  created_chapter_items WebinarChapterItem[]              @relation("ChapterItemCreator")
  created_files         Files[]                           @relation("FileCreator")
  created_attachments   WebinarAssignmentAttachment[]     @relation("AttachmentCreator")
  assignment_messages   WebinarAssignmentHistoryMessage[] @relation("AssignmentMessageSender")
  created_promocodes    Promocode[]                       @relation("PromocodeCreator")
  promocode_usages      PromocodeUsage[]                  @relation("PromocodeUsageUser")
  course_learnings      CourseLearning[]                  @relation("CourseLearningUser")

  course_content_overrides         CourseContentOverride[] @relation("UserContentOverrides")
  granted_course_content_overrides CourseContentOverride[] @relation("AdminGrantedContentOverrides")

  push_notification_logs PushNotificationLog[]

  scheduled_pushes_created   ScheduledPush[] @relation("ScheduledPushCreator")
  scheduled_pushes_cancelled ScheduledPush[] @relation("ScheduledPushCanceller")
  mailing_logs_received      MailingLog[]    @relation("MailingLogRecipient")
  mailing_logs_sent          MailingLog[]    @relation("MailingLogSender")

  @@index([created_at], name: "idx_users_created_at")
  @@map("users")
}

model Role {
  id            Int     @id @default(autoincrement()) @db.UnsignedInt
  name          String  @db.VarChar(64)
  code          String  @unique @default("") @db.VarChar(64)
  description   String? @db.VarChar(255)
  is_admin      Boolean @default(false)
  is_system     Boolean @default(false)
  display_order Int     @default(1000) @db.UnsignedInt
  created_at    Int     @db.UnsignedInt
  updated_at    Int?    @db.UnsignedInt

  users       User[]           @relation("RoleUsers")
  permissions RolePermission[] @relation("RolePermissions")

  @@map("roles")
}

// Phase 11 — RBAC. Tables created by glucose-api/prisma/migrations/phase-11-rbac-permissions.draft.sql.
// PascalCase model names + @@map for client API ergonomics (allowed under PRISMA.md "trim manually").
model PermissionGroup {
  id            Int          @id @default(autoincrement()) @db.UnsignedInt
  code          String       @unique @db.VarChar(64)
  name_ru       String       @db.VarChar(128)
  name_kz       String       @db.VarChar(128)
  display_order Int          @db.UnsignedInt
  created_at    Int          @db.UnsignedInt

  permissions Permission[] @relation("GroupPermissions")

  @@map("permission_groups")
}

model Permission {
  id            Int     @id @default(autoincrement()) @db.UnsignedInt
  group_id      Int     @db.UnsignedInt
  code          String  @unique @db.VarChar(96)
  action        String  @db.VarChar(32)
  name_ru       String  @db.VarChar(128)
  name_kz       String  @db.VarChar(128)
  description   String? @db.VarChar(255)
  display_order Int     @db.UnsignedInt

  group       PermissionGroup  @relation("GroupPermissions", fields: [group_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  role_grants RolePermission[] @relation("PermissionGrants")

  @@index([group_id], map: "idx_permissions_group_id")
  @@map("permissions")
}

model RolePermission {
  role_id       Int  @db.UnsignedInt
  permission_id Int  @db.UnsignedInt
  granted_at    Int  @db.UnsignedInt
  granted_by    Int? @db.UnsignedInt

  permission Permission @relation("PermissionGrants", fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  role       Role       @relation("RolePermissions", fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([role_id, permission_id])
  @@index([permission_id], map: "idx_role_permissions_permission_id")
  @@map("role_permissions")
}

model Group {
  id            Int         @id @default(autoincrement()) @db.UnsignedInt
  creator_id    Int         @db.UnsignedInt
  supervisor_id Int?        @db.UnsignedInt
  name          String      @db.VarChar(64)
  status        GroupStatus @default(inactive)

  creator           User                     @relation("GroupCreator", fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  supervisor        User?                    @relation("GroupSupervisor", fields: [supervisor_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  members           GroupUser[]              @relation("GroupMembers")
  chapter_schedules WebinarChapterSchedule[] @relation("ScheduleGroup")
  lesson_schedules  LessonSchedule[]         @relation("LessonScheduleGroup")
  notifications     Notification[]           @relation("NotificationGroup")
  sales             Sale[]                   @relation("GroupSales")
  content_overrides CourseContentOverride[]  @relation("GroupContentOverrides")

  @@map("groups")
}

model GroupUser {
  id         Int @id @default(autoincrement())
  user_id    Int @db.UnsignedInt
  group_id   Int @db.UnsignedInt
  created_at Int

  user  User  @relation("GroupUsers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  group Group @relation("GroupMembers", fields: [group_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("group_users")
}

model UserReferralCode {
  id         Int      @id @default(autoincrement())
  user_id    Int      @unique @db.UnsignedInt
  code       String   @db.VarChar(6)
  created_at DateTime @default(now())

  user User @relation("UserReferralCode", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("user_referral_code")
}

//* Авторизация
model Verification {
  id          Int     @id @default(autoincrement())
  user_id     Int?    @db.UnsignedInt
  mobile      String? @db.VarChar(16)
  email       String? @db.VarChar(64)
  code        String  @db.VarChar(6)
  verified_at Int?    @db.UnsignedInt
  expired_at  Int?    @db.UnsignedInt
  created_at  Int

  user User? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("verifications")
}

model UserLoginHistory {
  id               Int             @id @default(autoincrement())
  user_id          Int             @db.UnsignedInt
  browser          String?         @db.VarChar(255)
  device           String?         @db.VarChar(255)
  os               String?         @db.VarChar(255)
  ip               String?         @db.VarChar(255)
  country          String?         @db.VarChar(255)
  city             String?         @db.VarChar(255)
  session_id       String          @db.Text
  session_start_at BigInt          @db.UnsignedBigInt
  session_end_at   BigInt?         @db.UnsignedBigInt
  end_session_type SessionEndType?
  created_at       BigInt          @db.UnsignedBigInt

  user User @relation("UserLoginHistories", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("user_login_histories")
}

model UserFirebaseSession {
  id         BigInt  @id @default(autoincrement())
  user_id    Int     @db.UnsignedInt
  token      String  @db.Text
  fcm_token  String? @db.Text
  ip         String  @db.VarChar(255)
  created_at Int?
  updated_at Int?

  user User @relation("UserFirebaseSessions", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("user_firebase_sessions")
}

//* Регион
model Region {
  id          Int        @id @default(autoincrement())
  country_id  Int?
  province_id Int?
  city_id     Int?
  district_id Int?
  type        RegionType
  created_at  Int        @db.UnsignedInt

  country  Region? @relation("CountryProvinces", fields: [country_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  province Region? @relation("ProvinceCities", fields: [province_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  city     Region? @relation("CityDistricts", fields: [city_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  district Region? @relation("DistrictPlaces", fields: [district_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  provinces    Region[] @relation("CountryProvinces")
  cities       Region[] @relation("ProvinceCities")
  districts    Region[] @relation("CityDistricts")
  placeStudies Region[] @relation("DistrictPlaces")

  countryUsers  User[] @relation("CountryUsers")
  provinceUsers User[] @relation("ProvinceUsers")
  cityUsers     User[] @relation("CityUsers")
  districtUsers User[] @relation("DistrictUsers")
  schoolUsers   User[] @relation("SchoolUsers")

  promocodes Promocode[] @relation("PromocodeRegion")

  translations RegionTranslation[]

  universities University[] @relation("UniversityCity")

  @@map("regions")
}

model RegionTranslation {
  id        Int    @id @default(autoincrement())
  region_id Int
  locale    String @db.VarChar(191)
  title     String @db.VarChar(255)

  region Region @relation(fields: [region_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([region_id, locale])
  @@map("region_translations")
}

//* Предметы
model SchoolSubject {
  id         Int  @id @default(autoincrement())
  created_at Int
  updated_at Int?

  users User[] @relation("SchoolSubjectUsers")

  translations SchoolSubjectTranslation[]

  @@map("school_subjects")
}

model SchoolSubjectTranslation {
  id                Int    @id @default(autoincrement())
  school_subject_id Int
  locale            String @db.VarChar(191)
  title             String @db.VarChar(255)

  school_subject SchoolSubject @relation(fields: [school_subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("school_subject_translations")
}

//* Тесты
model Quizzes {
  id                         Int        @id @default(autoincrement())
  category_id                Int?
  subject_id                 Int?
  price                      Decimal?   @db.Decimal(15, 3)
  time                       Int?       @default(0)
  attempt                    Int?
  pass_mark                  Int
  certificate                Boolean
  status                     QuizStatus @default(active)
  total_mark                 Int?       @db.UnsignedInt
  display_questions_randomly Boolean    @default(false)
  expiry_days                Int?       @db.UnsignedInt
  version                    Int        @default(1)
  created_at                 Int
  updated_at                 Int?

  subject       QuizSubject?   @relation("QuizSubjects", fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  quiz_category QuizCategory?  @relation("QuizCategories", fields: [category_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  questions     QuizQuestion[] @relation("QuizQuestions")
  results       QuizResult[]   @relation("QuizResults")
  sales         Sale[]         @relation("QuizSales")
  carts         Cart[]         @relation(name: "QuizCarts")

  quiz_badge_items QuizBadgeItem[] @relation("QuizBadgeQuizzes")

  translations QuizTranslation[] @relation("QuizTranslations")

  webinar_quizzes WebinarQuiz[] @relation("WebinarQuizzes")
  order_items     OrderItem[]

  @@index([created_at], name: "idx_quizzes_created_at")
  @@map("quizzes")
}

model QuizTranslation {
  id      Int    @id @default(autoincrement())
  quiz_id Int    @db.UnsignedInt
  locale  String @db.VarChar(191)
  title   String @db.Text

  quiz Quizzes @relation("QuizTranslations", fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quiz_translations")
}

model QuizCategory {
  id         Int  @id @default(autoincrement())
  parent_id  Int?
  subject_id Int?
  created_at Int?
  updated_at Int?

  quizzes Quizzes[] @relation("QuizCategories")

  quiz_badges QuizBadge[] @relation("QuizCategoryBadges")

  subject  QuizSubject?   @relation("QuizSubjects", fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  parent   QuizCategory?  @relation("QuizCategoryParent", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  children QuizCategory[] @relation("QuizCategoryParent")

  translations QuizCategoryTranslation[] @relation("QuizCategoryTranslations")

  @@map("quiz_categories")
}

model QuizCategoryTranslation {
  id               Int    @id @default(autoincrement())
  quiz_category_id Int
  locale           String @db.VarChar(191)
  title            String @db.VarChar(255)

  quiz_category QuizCategory @relation("QuizCategoryTranslations", fields: [quiz_category_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quiz_category_translations")
}

model QuizSubject {
  id         Int  @id @default(autoincrement())
  created_at Int?
  updated_at Int?

  quizzes Quizzes[] @relation("QuizSubjects")

  categories   QuizCategory[]           @relation("QuizSubjects")
  translations QuizSubjectTranslation[] @relation("QuizSubjectTranslations")

  @@map("quiz_subjects")
}

model QuizSubjectTranslation {
  id              Int    @id @default(autoincrement())
  quiz_subject_id Int
  locale          String @db.VarChar(191)
  title           String @db.VarChar(255)

  quiz_subject QuizSubject @relation("QuizSubjectTranslations", fields: [quiz_subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quiz_subject_translations")
}

model QuizQuestion {
  id               Int              @id @default(autoincrement())
  quiz_id          Int              @db.UnsignedInt
  grade            Int
  answer_video_url String?          @db.VarChar(255)
  type             QuizQuestionType @default(single)
  image            String?          @db.Text
  video            String?          @db.Text
  order            Int?             @db.UnsignedInt
  created_at       Int
  updated_at       Int?

  quiz    Quizzes              @relation("QuizQuestions", fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  answers QuizQuestionAnswer[] @relation("QuizQuestionAnswers")

  translations QuizQuestionTranslation[] @relation("QuizQuestionTranslations")

  @@map("quizzes_questions")
}

model QuizQuestionTranslation {
  id                  Int     @id @default(autoincrement())
  quizzes_question_id Int     @db.UnsignedInt
  locale              String  @db.Char(255)
  title               String  @db.Text
  description         String? @db.Text
  correct             String? @db.Text

  question QuizQuestion @relation("QuizQuestionTranslations", fields: [quizzes_question_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quiz_question_translations")
}

model QuizQuestionAnswer {
  id          Int     @id @default(autoincrement())
  question_id Int     @db.UnsignedInt
  parent_id   Int?    @db.UnsignedInt
  image       String? @db.Text
  correct     Boolean @default(false)
  created_at  Int
  updated_at  Int?

  question QuizQuestion         @relation("QuizQuestionAnswers", fields: [question_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  parent   QuizQuestionAnswer?  @relation("QuizQuestionAnswers", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  children QuizQuestionAnswer[] @relation("QuizQuestionAnswers")

  translations QuizQuestionAnswerTranslation[] @relation("QuizQuestionAnswerTranslations")

  @@map("quizzes_questions_answers")
}

model QuizQuestionAnswerTranslation {
  id                          Int    @id @default(autoincrement())
  quizzes_questions_answer_id Int    @db.UnsignedInt
  locale                      String @db.VarChar(191)
  title                       String @db.Text

  quizzes_question_answer QuizQuestionAnswer @relation("QuizQuestionAnswerTranslations", fields: [quizzes_questions_answer_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quizzes_questions_answer_translations")
}

model QuizResult {
  id                    Int              @id @default(autoincrement())
  webinar_id            Int?             @db.UnsignedInt
  quiz_id               Int              @db.UnsignedInt
  quiz_version_at_start Int?
  user_id               Int              @db.UnsignedInt
  results               String?          @db.Text
  user_grade            Int?             @db.UnsignedInt
  status                QuizResultStatus @default(waiting)
  created_at            Int

  quiz Quizzes @relation("QuizResults", fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user User    @relation("QuizResults", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([user_id, quiz_id, status], name: "idx_quiz_results_lookup")
  @@map("quizzes_results")
}

model QuizBadge {
  id               Int       @id @default(autoincrement())
  is_active        Boolean   @default(true)
  quiz_category_id Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)

  quiz_category QuizCategory?     @relation("QuizCategoryBadges", fields: [quiz_category_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  items         QuizBadgeItem[]   @relation("QuizBadgeItems")
  results       QuizBadgeResult[] @relation("QuizBadgeResults")

  sales Sale[] @relation("QuizBadgeSales")

  translations QuizBadgeTranslation[] @relation("QuizBadgeTranslations")

  @@map("quiz_badges")
}

model QuizBadgeTranslation {
  id            Int    @id @default(autoincrement())
  quiz_badge_id Int
  locale        String @db.VarChar(191)
  title         String @db.VarChar(255)

  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)

  quiz_badge QuizBadge @relation("QuizBadgeTranslations", fields: [quiz_badge_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quiz_badge_translations")
}

model QuizBadgeItem {
  id            Int       @id @default(autoincrement())
  quiz_badge_id Int
  quiz_id       Int       @db.UnsignedInt
  order         Int?      @db.UnsignedInt
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)

  quiz_badge QuizBadge @relation("QuizBadgeItems", fields: [quiz_badge_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  quiz       Quizzes   @relation("QuizBadgeQuizzes", fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quiz_badge_items")
}

model QuizBadgeResult {
  id            Int              @id @default(autoincrement())
  user_id       Int              @db.UnsignedInt
  quiz_badge_id Int              @db.UnsignedInt
  results       Json
  user_grade    Int?
  status        QuizResultStatus @default(waiting)
  created_at    DateTime         @default(now()) @db.Timestamp(0)
  updated_at    DateTime?        @db.Timestamp(0)

  user       User      @relation("QuizBadgeResults", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  quiz_badge QuizBadge @relation("QuizBadgeResults", fields: [quiz_badge_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@map("quiz_badge_results")
}

//* Покупки
model Sale {
  id                       Int            @id @default(autoincrement())
  seller_id                Int?           @db.UnsignedInt
  buyer_id                 Int?           @db.UnsignedInt
  group_id                 Int?           @db.UnsignedInt
  order_id                 Int?           @db.UnsignedInt
  webinar_id               Int?           @db.UnsignedInt
  quiz_id                  Int?           @db.UnsignedInt
  quiz_badge_id            Int?           @db.UnsignedInt
  payment_method           PaymentMethod?
  type                     SaleType?
  amount                   Decimal        @db.Decimal(13, 2)
  tax                      Decimal?       @db.Decimal(13, 2)
  commission               Decimal?       @db.Decimal(13, 2)
  discount                 Decimal?       @db.Decimal(13, 2)
  total_amount             Decimal?       @db.Decimal(13, 2)
  manual_added             Boolean        @default(false)
  access_to_purchased_item Boolean        @default(true)
  created_at               Int            @db.UnsignedInt
  refund_at                Int?           @db.UnsignedInt
  access_days              Int?           @db.UnsignedInt

  webinar    Webinar?   @relation("WebinarSales", fields: [webinar_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  quiz       Quizzes?   @relation("QuizSales", fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  quiz_badge QuizBadge? @relation("QuizBadgeSales", fields: [quiz_badge_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  seller     User?      @relation("SaleSeller", fields: [seller_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  buyer      User?      @relation("SaleBuyer", fields: [buyer_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  group      Group?     @relation("GroupSales", fields: [group_id], references: [id], onDelete: SetNull, onUpdate: Restrict)
  order      Order?     @relation("OrderSales", fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([buyer_id, webinar_id], name: "idx_sales_buyer_webinar")
  @@index([group_id, webinar_id], name: "idx_sales_group_webinar")
  @@index([created_at], name: "idx_sales_created_at")
  @@map("sales")
}

model Order {
  id                   Int            @id @default(autoincrement())
  user_id              Int
  status               OrderStatus
  payment_method       PaymentMethod?
  amount               Decimal        @db.Decimal(15, 2)
  bonus_spent          Int?
  tax                  Decimal?       @db.Decimal(13, 2)
  total_discount       Decimal?       @db.Decimal(13, 2)
  total_amount         Decimal?       @db.Decimal(13, 2)
  product_delivery_fee Decimal?       @db.Decimal(13, 2)
  receipt              String?        @db.VarChar(500)
  created_at           Int

  items OrderItem[]

  user             User             @relation("OrderUser", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  sales            Sale[]           @relation("OrderSales")
  promocode_usages PromocodeUsage[] @relation("OrderPromocodeUsages")

  @@map("orders")
}

model OrderItem {
  id               Int      @id @default(autoincrement())
  order_id         Int
  webinar_id       Int?
  quiz_id          Int?
  price_id         Int?
  product_code     String?  @db.VarChar(255)
  amount           Decimal? @db.Decimal(15, 2)
  tax_price        Decimal? @db.Decimal(15, 2)
  commission_price Decimal? @db.Decimal(15, 2)
  discount         Decimal? @db.Decimal(15, 2)
  total_amount     Decimal? @db.Decimal(15, 2)
  created_at       Int?
  order            Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  webinar Webinar?       @relation(fields: [webinar_id], references: [id], onDelete: Cascade)
  quiz    Quizzes?       @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  price   WebinarPrices? @relation(fields: [price_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model KaspiPayment {
  id       Int     @id @default(autoincrement())
  txn_id   BigInt  @unique @db.UnsignedBigInt
  txn_date Int?    @db.UnsignedInt
  account  Int     @db.UnsignedInt
  sum      Decimal @db.Decimal(15, 3)
  data1    String? @db.Text
  data2    String? @db.Text
  data3    String? @db.Text
  data4    String? @db.Text
  data5    String? @db.Text
  data6    String? @db.Text
  data7    String? @db.Text
  data8    String? @db.Text
  data9    String? @db.Text
  data10   String? @db.Text

  status Int?

