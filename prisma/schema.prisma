//* Phase 8 — admin-scheduled push delivery queue. Cron in admin-api fires due rows
//* exactly-once across the cluster via @CronLock (Phase 1 Plan 04). attempt_id on
//* PushNotificationLog rows is computed deterministically from scheduled_push_id +
//* user_id so a duplicate cron tick (lock TTL exceeded) cannot double-write.
model ScheduledPush {
  id              BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  creator_id      Int                 @db.UnsignedInt
  title_ru        String              @db.VarChar(255)
  title_kz        String              @db.VarChar(255)
  body_ru         String              @db.Text
  body_kz         String              @db.Text
  category        String              @db.VarChar(32) // info | promo | reminder | system (D-05 user-facing category)
  deep_link       String?             @db.VarChar(512)
  audience        Json // serialized AudienceFilter (Plan 01 lib/audience/types.ts)
  scheduled_at    Int                 @db.UnsignedInt // Unix seconds, UTC; UI displays Asia/Almaty
  status          ScheduledPushStatus @default(pending)
  started_at      Int?                @db.UnsignedInt
  completed_at    Int?                @db.UnsignedInt
  delivered_count Int                 @default(0)
  failed_count    Int                 @default(0)
  audience_count  Int                 @default(0) // resolved at fire-time; 0 means not yet resolved
  cancelled_at    Int?                @db.UnsignedInt
  cancelled_by    Int?                @db.UnsignedInt
  error           String?             @db.Text // populated only on terminal failure
  created_at      Int                 @db.UnsignedInt
  updated_at      Int                 @db.UnsignedInt

  creator   User  @relation("ScheduledPushCreator", fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  canceller User? @relation("ScheduledPushCanceller", fields: [cancelled_by], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@index([status, scheduled_at], name: "idx_sched_push_status_at")
  @@index([creator_id, created_at], name: "idx_sched_push_creator_at")
  @@map("scheduled_pushes")
}

//* Phase 8 — mailing send log. Mirrors PushNotificationLog shape. attempt_id in meta
//* enables cross-process idempotency (admin-api cron + future glucose-api auto-mail).
model MailingLog {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id   Int      @db.UnsignedInt
  sender_id Int?     @db.UnsignedInt // null for system-issued mails
  subject   String   @db.VarChar(255)
  to_email  String   @db.VarChar(255)
  category  String   @db.VarChar(32) // marketing | transactional | reminder | system
  sent_at   DateTime @default(now()) @db.Timestamp(0)
  success   Boolean  @default(true)
  error     String?  @db.Text
  meta      Json? // { attempt_id, broadcast_id, audience_hash, smtp_message_id? }

  user   User  @relation("MailingLogRecipient", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  sender User? @relation("MailingLogSender", fields: [sender_id], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@index([user_id, sent_at], name: "idx_mailing_log_user_sent")
  @@index([sender_id, sent_at], name: "idx_mailing_log_sender_sent")
  @@map("mailing_logs")
}

//* Admin audit log — Phase 1 Plan 08 / SCH-01
//* Locked field shape mirrors AuditEntry interface in
//* glucose-admin-api/src/common/audit/audit.types.ts so the Phase 2 NDJSON
//* writes (logs/admin-audit.log) replay into this table without reshaping.
//* actor_id is intentionally NOT a foreign key relation to User — coupling
//* the audit log to FK cascade rules would lose audit history when users are
//* deleted (Pitfall 10).
model AdminAuditLog {
  id         BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  ts         Int // Unix seconds — matches glucose-api Math.floor(Date.now()/1000) convention
  actor_id   Int? // null only for @SkipAudit on public auth endpoints (login/refresh)
  action     String  @db.VarChar(64)
  entity     String  @db.VarChar(64)
  entity_id  String? @db.VarChar(64) // string-typed: works for BigInt + Int + composite ids
  ip         String? @db.VarChar(45) // IPv6-sized
  ua         String? @db.VarChar(512)
  before     Json?
  after      Json?
  meta       Json?
  bulk_op_id String? @db.VarChar(64) // populated via meta.bulk_op_id; promoted to its own column for index reach
  request_id String? @db.VarChar(64) // populated via meta.request_id once Phase 2 wires X-Request-Id

  @@index([actor_id, ts], name: "idx_admin_audit_actor_ts")
  @@index([entity, entity_id, ts], name: "idx_admin_audit_entity")
  @@index([bulk_op_id], name: "idx_admin_audit_bulk_op")
  @@map("admin_audit_logs")
}

