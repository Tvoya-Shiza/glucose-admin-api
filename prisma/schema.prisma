  created_at   Int     @db.UnsignedInt

  user    User           @relation(fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  webinar Webinar?       @relation(fields: [webinar_id], references: [id], onDelete: Cascade, onUpdate: Restrict, name: "WebinarCarts")
  quiz    Quizzes?       @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: Restrict, name: "QuizCarts")
  price   WebinarPrices? @relation(fields: [price_id], references: [id], onDelete: Cascade, onUpdate: Restrict, name: "PriceCarts")

  @@index([creator_id], name: "cart_creator_id_foreign")
  @@index([webinar_id], name: "cart_webinar_id_foreign")
  @@index([price_id], name: "cart_price_id_foreign")
  @@index([quiz_id], name: "cart_quiz_id_foreign")
  @@map("cart")
}

model Promocode {
  id                   Int      @id @default(autoincrement())
  code                 String   @unique @db.VarChar(255)
  title                String?  @db.VarChar(255)
  description          String?  @db.Text
  discount_type        String   @db.VarChar(255) // percentage, fixed
  discount_value       Decimal  @db.Decimal(10, 2)
  max_discount_amount  Decimal? @db.Decimal(15, 2)
  minimum_order_amount Decimal? @db.Decimal(15, 2)
  usage_limit          Int?     @db.Int
  usage_limit_per_user Int?     @db.Int
  is_active            Boolean  @db.TinyInt
  start_date           Int      @db.UnsignedInt
  expires_at           Int      @db.UnsignedInt
  creator_id           Int
  region_id            Int?
  applicable_to        Json? // JSON field containing array of applicable items
  excluded_items       Json? // JSON field containing array of excluded items
  first_purchase_only  Boolean  @default(false) @db.TinyInt
  created_at           Int      @db.UnsignedInt
  updated_at           Int      @db.UnsignedInt

  creator User             @relation("PromocodeCreator", fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  region  Region?          @relation("PromocodeRegion", fields: [region_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  usages  PromocodeUsage[] @relation("PromocodeUsages")

  @@map("promocodes")
}

model PromocodeUsage {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  promocode_id    Int      @db.UnsignedInt
  user_id         Int      @db.UnsignedInt
  order_id        Int      @db.UnsignedInt
  discount_amount Decimal? @db.Decimal(8, 2)
  order_amount    Decimal? @db.Decimal(8, 2)
  used_at         Int

  promocode Promocode @relation("PromocodeUsages", fields: [promocode_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  user      User      @relation("PromocodeUsageUser", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)
  order     Order     @relation("OrderPromocodeUsages", fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([promocode_id])
  @@index([user_id])
  @@map("promocode_usages")
}

model PushNotificationLog {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      Int      @db.UnsignedInt
  trigger_type String   @db.VarChar(100)
  sent_at      DateTime @default(now()) @db.Timestamp(0)
  success      Boolean  @default(true)
  meta         Json?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([user_id, trigger_type, sent_at], name: "idx_push_log_user_trigger_date")
  @@index([trigger_type, sent_at], name: "idx_push_log_trigger_date")
  @@map("push_notification_logs")
}

//* Admin audit log — Phase 1 Plan 08 / SCH-01
//* Locked field shape mirrors AuditEntry interface in
//* glucose-admin-api/src/common/audit/audit.types.ts so the Phase 2 NDJSON
//* writes (logs/admin-audit.log) replay into this table without reshaping.
//* actor_id is intentionally NOT a foreign key relation to User — coupling
//* the audit log to FK cascade rules would lose audit history when users are
//* deleted (Pitfall 10).
model AdminAuditLog {
  id         BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  ts         Int // Unix seconds — matches glucose-api Math.floor(Date.now()/1000) convention
  actor_id   Int? // null only for @SkipAudit on public auth endpoints (login/refresh)
  action     String  @db.VarChar(64)
  entity     String  @db.VarChar(64)
  entity_id  String? @db.VarChar(64) // string-typed: works for BigInt + Int + composite ids
  ip         String? @db.VarChar(45) // IPv6-sized
  ua         String? @db.VarChar(512)
  before     Json?
  after      Json?
  meta       Json?
  bulk_op_id String? @db.VarChar(64) // populated via meta.bulk_op_id; promoted to its own column for index reach
  request_id String? @db.VarChar(64) // populated via meta.request_id once Phase 2 wires X-Request-Id

  @@index([actor_id, ts], name: "idx_admin_audit_actor_ts")
  @@index([entity, entity_id, ts], name: "idx_admin_audit_entity")
  @@index([bulk_op_id], name: "idx_admin_audit_bulk_op")
  @@map("admin_audit_logs")
}
